-- =============================================
-- Regression Tests for semver Extension
-- =============================================
CREATE EXTENSION IF NOT EXISTS semver;
-- Basic input/output
SELECT '1.2.3'::semver;
 semver 
--------
 1.2.3
(1 row)

SELECT '0.0.1'::semver;
 semver 
--------
 0.0.1
(1 row)

SELECT '16.4.0'::semver;
 semver 
--------
 16.4.0
(1 row)

-- Invalid inputs
SELECT '1.2.x'::semver;
ERROR:  invalid input syntax for type semver: "1.2.x"
LINE 1: SELECT '1.2.x'::semver;
               ^
SELECT '1.2'::semver;
ERROR:  invalid input syntax for type semver: "1.2"
LINE 1: SELECT '1.2'::semver;
               ^
SELECT '1.2.3.4'::semver;
ERROR:  invalid input syntax for type semver: "1.2.3.4"
LINE 1: SELECT '1.2.3.4'::semver;
               ^
SELECT 'v1.2.3'::semver;
ERROR:  invalid input syntax for type semver: "v1.2.3"
LINE 1: SELECT 'v1.2.3'::semver;
               ^
-- Comparison operators
SELECT '1.10.0'::semver > '1.9.0'::semver;
 ?column? 
----------
 t
(1 row)

SELECT '1.2.3'::semver < '1.10.0'::semver;
 ?column? 
----------
 t
(1 row)

SELECT '1.2.3'::semver <= '1.2.3'::semver;
 ?column? 
----------
 t
(1 row)

SELECT '1.2.3'::semver = '1.2.3'::semver;
 ?column? 
----------
 t
(1 row)

SELECT '2.0.0'::semver >= '1.9.9'::semver;
 ?column? 
----------
 t
(1 row)

-- Utility Functions (Student C)
SELECT major('16.4.0'::semver);
 major 
-------
    16
(1 row)

SELECT minor('16.4.0'::semver);
 minor 
-------
     4
(1 row)

SELECT patch('16.4.0'::semver);
 patch 
-------
     0
(1 row)

SELECT bump_minor('1.2.3'::semver);
 bump_minor 
------------
 1.3.0
(1 row)

SELECT is_compatible('1.5.0'::semver, '1.4.7'::semver);
 is_compatible 
---------------
 t
(1 row)

SELECT is_compatible('2.0.0'::semver, '1.9.0'::semver);
 is_compatible 
---------------
 f
(1 row)

-- Real world usage (without ORDER BY to avoid operator class issue)
CREATE TABLE sv_test (name text, version semver);
INSERT INTO sv_test VALUES 
('postgres', '16.4.0'),
('node', '20.10.0'),
('nginx', '1.27.1'),
('redis', '7.2.5');
SELECT * FROM sv_test;
   name   | version 
----------+---------
 postgres | 16.4.0
 node     | 20.10.0
 nginx    | 1.27.1
 redis    | 7.2.5
(4 rows)

SELECT name, version, is_compatible(version, '1.0.0'::semver) FROM sv_test;
   name   | version | is_compatible 
----------+---------+---------------
 postgres | 16.4.0  | f
 node     | 20.10.0 | f
 nginx    | 1.27.1  | t
 redis    | 7.2.5   | f
(4 rows)

DROP TABLE sv_test;
